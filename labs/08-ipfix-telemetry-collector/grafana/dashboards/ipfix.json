{
  "title": "IPFIX Telemetry & SRE Metrics",
  "panels": [
    {
      "type": "stat",
      "title": "UDP Packets Received",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 0 },
      "targets": [
        { "expr": "sum(rate(ipfix_udp_packets_received_total[1m]))", "legendFormat": "Packets/sec" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Bandwidth per Flow (Bytes/sec)",
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 0 },
      "targets": [
        { "expr": "sum by (src_ip, dst_ip) (rate(ipfix_bytes_processed_total[1m]))", "legendFormat": "{{src_ip}} -> {{dst_ip}}" }
      ]
    }
  ],
  "schemaVersion": 30,
  "refresh": "5s"
}
